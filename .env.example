# ============================================
# DRL DDoS Detection Application Configuration
# ============================================
# Copy this file to .env and modify values as needed:
#   cp .env.example .env

# --- Flask Application ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true
FLASK_APP_URL=http://127.0.0.1:5000

# --- Packet Capture ---
# Network interface to capture packets from (use 'ip link' to list interfaces)
CAPTURE_INTERFACE=eth0
# Optional BPF filter (e.g., 'tcp port 80')
CAPTURE_FILTER=
# Rotate pcap files every N seconds
ROTATE_INTERVAL_SECONDS=30
# Maximum pcap file size in MB before rotation
ROTATE_MAX_SIZE_MB=50

# --- Dispatcher and Processing ---
DISPATCHER_POLL_INTERVAL_SECONDS=5
MAX_PROCESSING_WORKERS=4
PROCESSING_TIMEOUT_SECONDS=300
QUEUE_MAXSIZE=10
# Force CPU usage even if GPU is available
FORCE_CPU=true

# --- Feature Extraction Thresholds ---
FLOW_TIMEOUT_NS=1200000000
MAX_FLOW_DURATION_NS=120000000000
ACTIVE_THRESHOLD_US=1000000

# --- Paths ---
MODEL_PATH=./detection_module/trained_models/final_drl1.pt
PROCESSED_FEATURES_DIR=./capapp/features_output
PREDICTION_OUTPUT_DIR=./data/predictions

# --- Model Updater ---
# Remote API endpoint for model updates (set to your model server URL)
MODEL_API_URL=http://127.0.0.1:8000/api/pipeline/model/download
# How often to check for model updates (in hours)
MODEL_UPDATE_INTERVAL_HOURS=2
